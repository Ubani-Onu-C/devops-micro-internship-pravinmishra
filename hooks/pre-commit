#!/bin/bash
#
# pre-commit — blocks commits containing secret-like patterns or oversized files
#
# This hook is tracked in the repo (hooks/pre-commit) rather than living only
# in .git/hooks/, so every contributor gets the same checks automatically
# once core.hooksPath is configured — it's shared, version-controlled policy,
# not a private local preference.

BLOCKED=0
MAX_FILE_SIZE=1048576  # 1MB in bytes

# Patterns that look like common cloud/API secrets
SECRET_PATTERNS=(
    "AKIA[0-9A-Z]{16}"                  # AWS Access Key ID
    "aws_secret_access_key"
    "AIza[0-9A-Za-z_-]{35}"             # Google API key
    "ghp_[0-9A-Za-z]{36}"               # GitHub Personal Access Token
    "-----BEGIN.*PRIVATE KEY-----"       # Private key blocks
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for FILE in $STAGED_FILES; do
    # Don't scan the hook script itself — it legitimately contains the
    # pattern strings as literal definitions, which would always self-match
    if [ "$FILE" = "hooks/pre-commit" ]; then
        continue
    fi

    # Skip binary files
    if file "$FILE" | grep -q "text"; then

        # Check for secret-like patterns
        for PATTERN in "${SECRET_PATTERNS[@]}"; do
            if grep -E -q -- "$PATTERN" "$FILE"; then
                echo "BLOCKED: '$FILE' appears to contain a secret matching pattern: $PATTERN"
                BLOCKED=1
            fi
        done

        # Check for leftover debug statements
        if grep -E -q -- "DEBUG:|console\.log\(|print\(.*DEBUG" "$FILE"; then
            echo "WARNING: '$FILE' contains a debug statement — consider removing before commit"
        fi
    fi

    # Check file size
    if [ -f "$FILE" ]; then
        FILE_SIZE=$(stat -c%s "$FILE" 2>/dev/null || stat -f%z "$FILE" 2>/dev/null)
        if [ "$FILE_SIZE" -gt "$MAX_FILE_SIZE" ]; then
            echo "BLOCKED: '$FILE' is $FILE_SIZE bytes, exceeding the 1MB limit"
            BLOCKED=1
        fi
    fi
done

if [ "$BLOCKED" -eq 1 ]; then
    echo ""
    echo "Commit rejected. Remove the flagged secrets or oversized files, then try again."
    exit 1
fi

exit 0